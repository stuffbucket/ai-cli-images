{
  "name": "@stuffbucket/ai-cli-images-monorepo",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "@stuffbucket/ai-cli-images-monorepo",
      "license": "MIT",
      "workspaces": [
        "packages/core",
        "packages/key-proxy",
        "packages/clis/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@stuffbucket/ai-cli-claude": {
      "resolved": "packages/clis/claude-code",
      "link": true
    },
    "node_modules/@stuffbucket/ai-cli-codex": {
      "resolved": "packages/clis/codex",
      "link": true
    },
    "node_modules/@stuffbucket/ai-cli-copilot": {
      "resolved": "packages/clis/copilot",
      "link": true
    },
    "node_modules/@stuffbucket/ai-cli-core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@stuffbucket/ai-cli-key-proxy": {
      "resolved": "packages/key-proxy",
      "link": true
    },
    "packages/clis/claude-code": {
      "name": "@stuffbucket/ai-cli-claude",
      "version": "2.1.158",
      "license": "MIT",
      "dependencies": {
        "@stuffbucket/ai-cli-core": "^0.1.0"
      },
      "bin": {
        "ai-cli-claude": "run.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/clis/codex": {
      "name": "@stuffbucket/ai-cli-codex",
      "version": "0.135.0",
      "license": "MIT",
      "dependencies": {
        "@stuffbucket/ai-cli-core": "^0.1.0"
      },
      "bin": {
        "ai-cli-codex": "run.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/clis/copilot": {
      "name": "@stuffbucket/ai-cli-copilot",
      "version": "1.0.56",
      "license": "MIT",
      "dependencies": {
        "@stuffbucket/ai-cli-core": "^0.1.0"
      },
      "bin": {
        "ai-cli-copilot": "run.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/core": {
      "name": "@stuffbucket/ai-cli-core",
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=20"
      }
    },
    "packages/key-proxy": {
      "name": "@stuffbucket/ai-cli-key-proxy",
      "version": "0.1.0",
      "license": "MIT",
      "bin": {
        "ai-cli-key-proxy": "bin.js"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
